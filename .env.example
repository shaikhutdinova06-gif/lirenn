# AI API Keys
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# Sentinel Hub Credentials (for satellite imagery)
# Get your API Key (Instance ID) at: https://www.sentinel-hub.com/
# 1. Create account at https://www.sentinel-hub.com/
# 2. Go to Dashboard -> User Settings (click your name -> Settings)
# 3. Copy your API Key (Instance ID) from the API Key section
# 4. Paste it below - it looks like: PLAKxxxxxxxxxxxxxxxxxxxxxxxxxx
SENTINEL_INSTANCE_ID=your_api_key_here

# Note: These environment variables are automatically loaded by Docker/Amvera
# Make sure to set them in your deployment platform's environment settings
