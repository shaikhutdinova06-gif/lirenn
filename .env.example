# AI API Keys
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# Sentinel Hub OAuth Credentials (for satellite imagery)
# 1. Create account at https://www.sentinel-hub.com/
# 2. Go to Dashboard -> User Settings
# 3. Click "Create new OAuth client"
# 4. Copy Client ID and Client Secret below
#
# Format:
# Client ID: TcXdcr0FAOkbwGfFC1PNgeRNJUX4H1T6 (example)
# Client Secret: a9ae8169-9c86-4bc9-a64b-ad907736c1f9 (example)
SENTINEL_CLIENT_ID=your_client_id_here
SENTINEL_CLIENT_SECRET=your_client_secret_here

# Note: These environment variables are automatically loaded by Docker/Amvera
# Make sure to set them in your deployment platform's environment settings
