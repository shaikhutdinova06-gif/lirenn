# AI API Keys
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# Sentinel Hub Credentials (for satellite imagery)
# Get your credentials at: https://www.sentinel-hub.com/
# 1. Create account
# 2. Go to Dashboard -> User Settings
# 3. Create OAuth client
# 4. Copy Client ID and Client Secret here
SENTINEL_CLIENT_ID=your_sentinel_client_id_here
SENTINEL_CLIENT_SECRET=your_sentinel_client_secret_here

# Note: These environment variables are automatically loaded by Docker/Amvera
# Make sure to set them in your deployment platform's environment settings
